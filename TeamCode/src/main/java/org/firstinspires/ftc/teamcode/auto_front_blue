package org.firstinspires.ftc.teamcode;

import com.qualcomm.robotcore.eventloop.opmode.Autonomous;
import com.qualcomm.robotcore.eventloop.opmode.LinearOpMode;
import com.qualcomm.robotcore.hardware.DcMotor;
import com.qualcomm.robotcore.hardware.Servo;
import com.qualcomm.robotcore.util.ElapsedTime;
import com.qualcomm.robotcore.hardware.VoltageSensor;


@Autonomous(name="Carter Front Blue Auto", group="Robot")
public class auto_front_blue extends LinearOpMode {

    // Declare motors and servo
    
    private DcMotor frontLeftDrive = null;
    private DcMotor backLeftDrive = null;
    private DcMotor frontRightDrive = null;
    private DcMotor backRightDrive = null;

    private DcMotor top_shooter = null;
    private DcMotor bottom_shooter = null;
    private DcMotor intake = null;
    private Servo myServo = null;
    private DcMotor feeder = null;
    private ElapsedTime runtime = new ElapsedTime();

    // --- Constants (tune for your robot) ---
    static final double COUNTS_PER_MOTOR_REV = 384.5;  // eg: TETRIX Motor Encoder
    static final double DRIVE_GEAR_REDUCTION = 1.0;   // No External Gearing
    static final double WHEEL_DIAMETER_INCHES = 3.78;
    static final double COUNTS_PER_INCH = (COUNTS_PER_MOTOR_REV * DRIVE_GEAR_REDUCTION) /
            (WHEEL_DIAMETER_INCHES * 3.1415);
    static final double DRIVE_SPEED = 0.8;
    static final double TURN_SPEED  = 0.6;
    private VoltageSensor voltageSensor;

    private double MAX_VOLTAGE = 14.0;

    @Override
    public void runOpMode() {

        // --- Hardware Map ---
        frontLeftDrive  = hardwareMap.get(DcMotor.class, "front_left_drive");
        frontRightDrive = hardwareMap.get(DcMotor.class, "front_right_drive");
        backLeftDrive   = hardwareMap.get(DcMotor.class, "back_left_drive");
        backRightDrive  = hardwareMap.get(DcMotor.class, "back_right_drive");
        top_shooter     = hardwareMap.get(DcMotor.class, "top_shooter");
        bottom_shooter  = hardwareMap.get(DcMotor.class, "bottom_shooter");
        intake          = hardwareMap.get(DcMotor.class, "intake");
        myServo         = hardwareMap.get(Servo.class, "servo");
        feeder = hardwareMap.get(DcMotor.class, "feeder");
        voltageSensor = hardwareMap.get(VoltageSensor.class, "Control Hub");



        // --- Motor Directions ---
        frontLeftDrive.setDirection(DcMotor.Direction.FORWARD);
        backLeftDrive.setDirection(DcMotor.Direction.FORWARD);
        frontRightDrive.setDirection(DcMotor.Direction.REVERSE);
        backRightDrive.setDirection(DcMotor.Direction.REVERSE);

        top_shooter.setDirection(DcMotor.Direction.REVERSE);
        bottom_shooter.setDirection(DcMotor.Direction.FORWARD);
        intake.setDirection(DcMotor.Direction.FORWARD);
        feeder.setDirection(DcMotor.Direction.REVERSE);

        // --- Encoder Reset ---
        frontLeftDrive.setMode(DcMotor.RunMode.STOP_AND_RESET_ENCODER);
        frontRightDrive.setMode(DcMotor.RunMode.STOP_AND_RESET_ENCODER);
        backLeftDrive.setMode(DcMotor.RunMode.STOP_AND_RESET_ENCODER);
        backRightDrive.setMode(DcMotor.RunMode.STOP_AND_RESET_ENCODER);

        frontLeftDrive.setZeroPowerBehavior(DcMotor.ZeroPowerBehavior.BRAKE);
        frontRightDrive.setZeroPowerBehavior(DcMotor.ZeroPowerBehavior.BRAKE);
        backLeftDrive.setZeroPowerBehavior(DcMotor.ZeroPowerBehavior.BRAKE);
        backRightDrive.setZeroPowerBehavior(DcMotor.ZeroPowerBehavior.BRAKE);

        telemetry.addLine("Encoders Reset. Ready to start.");
        telemetry.update();

        frontLeftDrive.setMode(DcMotor.RunMode.RUN_USING_ENCODER);
        frontRightDrive.setMode(DcMotor.RunMode.RUN_USING_ENCODER);
        backLeftDrive.setMode(DcMotor.RunMode.RUN_USING_ENCODER);
        backRightDrive.setMode(DcMotor.RunMode.RUN_USING_ENCODER);

        waitForStart();

        // --- Step 1: Spin shooter motors ---
        double top_shooter_pwr;
        double bot_shooter_pwr;
        double currentVoltage = voltageSensor.getVoltage();
        double shot_pwr_adjust = 1 + ((MAX_VOLTAGE - currentVoltage) / MAX_VOLTAGE);

        currentVoltage = voltageSensor.getVoltage();
        shot_pwr_adjust = 1 + ((MAX_VOLTAGE - currentVoltage) / MAX_VOLTAGE);
        top_shooter_pwr = 0.75;
        bot_shooter_pwr = -0.75;

        top_shooter_pwr *= shot_pwr_adjust;
        bot_shooter_pwr *= shot_pwr_adjust;
        top_shooter.setPower(top_shooter_pwr);
        bottom_shooter.setPower(bot_shooter_pwr);


        // --- Step 2: Drive forward 45 inches ---
        encoderDrive(DRIVE_SPEED, 47, 45, 47, 45, 5.0);
        //encoderDrive(TURN_SPEED, -1.5, 1.5, -1.5, 6.5, 1.0);
        sleep(500);
        // --- Step 3: Spin feeder and intake motors ---
        feeder.setPower(1.0);
        intake.setPower(-1.0);
        sleep(100);
        feeder.setPower(0.0);
        intake.setPower(0.0);
        sleep(500);
        feeder.setPower(1.0);
        intake.setPower(-1.0);
        sleep(200);
        feeder.setPower(0.0);
        intake.setPower(0.0);
        sleep(500);
        feeder.setPower(1.0);
        intake.setPower(-1.0);
        sleep(100);
        feeder.setPower(0.0);
        intake.setPower(0.0);
        sleep(500);
        feeder.setPower(1.0);
        intake.setPower(-1.0);
        sleep(100);
        feeder.setPower(0.0);
        intake.setPower(0.0);
        sleep(500);
        feeder.setPower(1.0);
        intake.setPower(-1.0);
        sleep(1000);
        feeder.setPower(0.0);
        intake.setPower(0.0);


        // --- Step 4: Stop shooter motors ---
        top_shooter.setPower(0.0);
        bottom_shooter.setPower(0.0);
        feeder.setPower(0.0);
        // --- Step 5: Turn left (in place) ---
        // Left wheels forward, right wheels backward
        encoderDrive(TURN_SPEED, 34, -34, 34, -34, 3.0);
        encoderDrive(DRIVE_SPEED, -3, 3, 3, -3, 2.0);
        // --- Step 6: Drive forward again 24 inches ---
        feeder.setPower(-0.5);
        intake.setPower(-1.0);
        encoderDrive(0.25, 46, 46, 46, 46, 7.0);

        sleep(500);

        // --- Step 7: spin up shooter
        currentVoltage = voltageSensor.getVoltage();
        shot_pwr_adjust = 1 + ((MAX_VOLTAGE - currentVoltage) / MAX_VOLTAGE);
        top_shooter_pwr = 0.75;
        bot_shooter_pwr = -0.75;

        top_shooter_pwr *= shot_pwr_adjust;
        bot_shooter_pwr *= shot_pwr_adjust;
        top_shooter.setPower(top_shooter_pwr);
        bottom_shooter.setPower(bot_shooter_pwr);


        // --- Step 7: Drive back to shooting zone ---
        encoderDrive(0.4, -35, -35, -35, -35, 2.0);
        encoderDrive(TURN_SPEED, -32.5, 32.5, -32.5, 32.5, 3.0);
        sleep(1000);


        // --- Step 9: Spin feeder and intake motors ---
        //I just made it pulse a ton of times ;)
        feeder.setPower(1.0);
        intake.setPower(-1.0);
        sleep(100);
        intake.setPower(0.0);
        feeder.setPower(0.0);
        sleep(500);
        feeder.setPower(1.0);
        intake.setPower(-1.0);
        sleep(200);
        intake.setPower(0.0);
        feeder.setPower(0.0);
        sleep(500);
        feeder.setPower(1.0);
        intake.setPower(-1.0);
        sleep(200);
        intake.setPower(0.0);
        feeder.setPower(0.0);
        sleep(500);
        feeder.setPower(1.0);
        intake.setPower(-1.0);
        sleep(200);
        intake.setPower(0.0);
        feeder.setPower(0.0);
        sleep(500);
        intake.setPower(-1.0);
        feeder.setPower(1.0);
        sleep(200);
        intake.setPower(0.0);
        feeder.setPower(0.0);
        sleep(500);
        feeder.setPower(1.0);
        intake.setPower(-1.0);
        sleep(1000);
        intake.setPower(0.0);
        feeder.setPower(0.0);
        sleep(500);


        // --- Step 10: Stop shooter motors ---
        top_shooter.setPower(0.0);
        bottom_shooter.setPower(0.0);
        feeder.setPower(0.0);
        sleep(1000);

        // --- Step 11: Strafe off line
        encoderDrive(DRIVE_SPEED, 24, -24, -24, 24, 2.0);

        telemetry.addData("Path", "Complete");
        telemetry.update();
        sleep(1000);
    }

    // --- Helper Method for Encoder Drive ---
    public void encoderDrive(double speed,
                             double flInches, double frInches,
                             double blInches, double brInches,
                             double timeoutS) {

        int newFLTarget, newFRTarget, newBLTarget, newBRTarget;

        // Calculate new target positions
        newFLTarget = frontLeftDrive.getCurrentPosition() + (int)(flInches * COUNTS_PER_INCH);
        newFRTarget = frontRightDrive.getCurrentPosition() + (int)(frInches * COUNTS_PER_INCH);
        newBLTarget = backLeftDrive.getCurrentPosition() + (int)(blInches * COUNTS_PER_INCH);
        newBRTarget = backRightDrive.getCurrentPosition() + (int)(brInches * COUNTS_PER_INCH);

        // Set new target positions
        frontLeftDrive.setTargetPosition(newFLTarget);
        frontRightDrive.setTargetPosition(newFRTarget);
        backLeftDrive.setTargetPosition(newBLTarget);
        backRightDrive.setTargetPosition(newBRTarget);

        // Switch to RUN_TO_POSITION mode
        frontLeftDrive.setMode(DcMotor.RunMode.RUN_TO_POSITION);
        frontRightDrive.setMode(DcMotor.RunMode.RUN_TO_POSITION);
        backLeftDrive.setMode(DcMotor.RunMode.RUN_TO_POSITION);
        backRightDrive.setMode(DcMotor.RunMode.RUN_TO_POSITION);

        // Start moving
        runtime.reset();
        frontLeftDrive.setPower(Math.abs(speed));
        frontRightDrive.setPower(Math.abs(speed));
        backLeftDrive.setPower(Math.abs(speed));
        backRightDrive.setPower(Math.abs(speed));

        while (opModeIsActive() &&
                (runtime.seconds() < timeoutS) &&
                (frontLeftDrive.isBusy() && frontRightDrive.isBusy() &&
                        backLeftDrive.isBusy() && backRightDrive.isBusy())) {

            telemetry.addData("Running to", "%7d :%7d :%7d :%7d",
                    newFLTarget, newFRTarget, newBLTarget, newBRTarget);
            telemetry.addData("Currently at", "%7d :%7d :%7d :%7d",
                    frontLeftDrive.getCurrentPosition(),
                    frontRightDrive.getCurrentPosition(),
                    backLeftDrive.getCurrentPosition(),
                    backRightDrive.getCurrentPosition());
            telemetry.update();
        }

        // Stop motors
        stopDrive();

        // Return to normal encoder mode
        frontLeftDrive.setMode(DcMotor.RunMode.RUN_USING_ENCODER);
        frontRightDrive.setMode(DcMotor.RunMode.RUN_USING_ENCODER);
        backLeftDrive.setMode(DcMotor.RunMode.RUN_USING_ENCODER);
        backRightDrive.setMode(DcMotor.RunMode.RUN_USING_ENCODER);

        sleep(250);
    }

    private void stopDrive() {
        frontLeftDrive.setPower(0);
        frontRightDrive.setPower(0);
        backLeftDrive.setPower(0);
        backRightDrive.setPower(0);
    }
}
